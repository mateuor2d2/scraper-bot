# =============================================================================
# .env.example — cima20paas / Traefik deployment template for Rust HTTP apps
# Copy to .env and fill in real values before deploying.
# =============================================================================

# ── Project identity ────────────────────────────────────────────────────
# Used for container naming, Traefik router names, and volume prefixes.
APP_NAME=rust-http-app

# Used by docker compose for project-wide resource naming.
COMPOSE_PROJECT_NAME=rust-http-app

# ── Domain / public URL ─────────────────────────────────────────────────
# The public domain that will point to this app (used by Traefik Host rule).
DOMAIN=app.example.com

# Alias (optional): additional domain that resolves to the same app.
# DOMAIN_ALIAS=

# ── Docker image ────────────────────────────────────────────────────────
# Full image reference. Override if you use a registry (GHCR, Docker Hub).
# If building locally, leave commented out and run: docker compose build
DOCKER_IMAGE=ghcr.io/OWNER/rust-http-app:latest
# GITHUB_REPO_OWNER=example
# GITHUB_REPO_NAME=rust-http-app
# IMAGE_TAG=latest

# ── App runtime ─────────────────────────────────────────────────────────
# UID/GID of the non-root user inside the container (must match Dockerfile).
APP_UID=1000
APP_GID=1000

# Port the app listens on INSIDE the container.
# Must match the port your Axum/Actix app binds to.
PORT=8080

# Alias used in docker-compose environment passthrough.
APP_PORT=8080

# Directory inside the container for persistent data (SQLite, uploads, etc.)
APP_DATA_DIR=/app/data

# Rust log level: error | warn | info | debug | trace
RUST_LOG=info

# Database connection string (empty = no DB / SQLite default).
# Examples:
#   sqlite:/app/data/app.db
#   postgres://user:pass@db:5432/appdb
DATABASE_URL=

# ── Traefik / networking ───────────────────────────────────────────────
# Traefik router name (used in label keys). Defaults to COMPOSE_PROJECT_NAME.
TRAEFIK_ROUTER_NAME=rust-http-app

# Traefik Host rule domain. Usually the same as DOMAIN.
TRAEFIK_HOST=app.example.com

# External Docker network shared with Traefik reverse proxy.
TRAEFIK_NETWORK=MYAPP-frontend

# ── Security (optional) ────────────────────────────────────────────────
# Admin token for protected endpoints (if your app uses one).
# ADMIN_TOKEN=

# Telegram bot token (if the app is a Telegram bot).
# TELOXIDE_TOKEN=

# ── Build args (used by Dockerfile) ────────────────────────────────────
# Must match the binary name in Cargo.toml [package].name.
# APP_BUILD_NAME=rust-http-app
